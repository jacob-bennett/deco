{
  "name": "@jacben/deco",
  "version": "0.2.0",
  "description": "Zero dependency collection of composable asynchronous decorators.",
  "keywords": [
    "coalesce",
    "concurrency",
    "limit",
    "deduplicate",
    "deduplication",
    "async",
    "optimization",
    "request"
  ],
  "bugs": {
    "url": "https://github.com/jacob-bennett/deco/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacob-bennett/deco.git"
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "license": "MIT",
  "author": "Jacob Bennett <jacob@jacobbennett.tech>",
  "exports": {
    ".": {
      "types": "./dist/deco.d.ts",
      "default": "./dist/deco.js"
    }
  },
  "type": "module",
  "main": "dist/deco.js",
  "sideEffects": false,
  "directories": {
    "test": "test"
  },
  "types": "dist/deco.d.ts",
  "scripts": {
    "test": "npm run typecheck && node --test test/*",
    "test:cov": "node --test --experimental-test-coverage test/*",
    "build": "tsc",
    "fix": "npm run lint && npm run format && npm run typecheck && echo '> Running tests...' && node --test --test-reporter=dot ./test/* && echo '> Tests passed!'",
    "check": "npm run lint:check && npm run format:check && npm run typecheck && echo '> Running tests...' && node --test --test-reporter=dot ./test/* && echo '> Tests passed!'",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint --flag unstable_native_nodejs_ts_config . --fix",
    "lint:check": "eslint --flag unstable_native_nodejs_ts_config .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.2.3",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.1"
  }
}
