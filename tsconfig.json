{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022"],
    "erasableSyntaxOnly": true,
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rewriteRelativeImportExtensions": true,
    "types": []
  },
  "include": ["./src/**/*.js", "./src/**/*.ts"]
}
